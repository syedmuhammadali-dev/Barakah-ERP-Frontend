{
  "extends": "./tsconfig.base.json",
  "include": [
    "next-env.d.ts",
    "global.d.ts",
    "pages/**/*",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "strict": false,
    "incremental": true,
    "esModuleInterop": true
  },
  "references": [
    {
      "path": "./lib/api-client-react"
    },
    {
      "path": "./lib/auth-web"
    }
  ]
}
